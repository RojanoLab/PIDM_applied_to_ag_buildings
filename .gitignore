# Python cache and bytecode
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Packaging / build artifacts
build/
dist/
*.egg-info/
.eggs/

# Logs and local environment files
*.log
.env
.env.*

# IDE / editor
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Model artifacts
*.pt
*.pth
*.ckpt
*.onnx

# Large array dumps
*.npy
*.npz

# Keep required project folders even if empty
# (Git doesn't track empty folders, so keep .gitkeep files)

data/*
!data/.gitkeep

images/*
!images/.gitkeep

experiments/*
!experiments/.gitkeep

pretrained_weights/*
!pretrained_weights/.gitkeep

train_ddpm/experiments/*
!train_ddpm/experiments/.gitkeep

train_ddpm/runs/*
!train_ddpm/runs/.gitkeep

# Jupyter
.ipynb_checkpoints/
